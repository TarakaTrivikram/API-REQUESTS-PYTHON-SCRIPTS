    with spyder.post('http://localhost') as post:
##    with spyder.browser(version='4700') as browser:
##################################################
        url = "https://ncreif.org/news/"
        response = requests.get(url,verify=False)
        tree=response.content
        #print(tree)

        # Parse the HTML content
        tree = html.fromstring(response.content)

        # Use XPath to find anchor tags with the desired href
        links = tree.xpath('//a[contains(@href, "Expanded-NPI-Snapshot-Flash-")]')
        href = links[0].get("href")

        pdf_url = "https://ncreif.org/" + href
        response = requests.get(pdf_url, verify=False)
        outputfilename = "%s\%s.pdf"%(parameters.download_directory,parameters.thread_name)
        if response.status_code == 200:
            with open(outputfilename, "wb") as f:
                f.write(response.content)
        else:
            print("Failed to download:", response.status_code)


        print(outputfilename)

        post.downloaded_files.append(outputfilename)
        post.writeline_log('FILE;{0};'.format(outputfilename))

